{:paths ["scripts"]
 :tasks
 {:requires ([validate]
             [publish]
             [bump-versions])

  validate {:doc "Validate plugin structure (JSON, paths, marketplace consistency)"
            :task (validate/validate!)}

  publish {:doc "Validate and push a [publish] marker commit to trigger CI release"
           :task (publish/publish! {:dry-run (some #{"--dry-run"} *command-line-args*)})}

  ci-release {:doc "CI-only: update changelog, version, and README for a release"
              :task (let [version (first *command-line-args*)]
                      (when-not version
                        (println "Usage: bb ci-release <version>")
                        (System/exit 1))
                      (bump-versions/bump-versions! {})
                      (bump-versions/generate-readmes!)
                      (publish/ci-release! version)
                      (publish/update-readme!))}

  update-readme {:doc "Regenerate the plugins table in README.md from marketplace.json"
                 :task (publish/update-readme!)}

  bump-version {:doc "CI-only: bump marketplace version without changelog changes"
                :task (let [version (first *command-line-args*)]
                        (when-not version
                          (println "Usage: bb bump-version <version>")
                          (System/exit 1))
                        (publish/bump-version! version))}

  bump-plugin-versions {:doc "Bump plugin.json versions for plugins with content changes since last version bump"
                        :task (bump-versions/bump-versions!
                               {:dry-run (some #{"--dry-run"} *command-line-args*)})}

  generate-plugin-readmes {:doc "Generate README.md for each plugin from plugin.json and skill/agent frontmatter"
                           :task (bump-versions/generate-readmes!)}}}
